{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure-release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset", "windows-mingw-release"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "configure-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset", "windows-mingw-debug"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "--preset", "windows-mingw-release"
      ],
      "dependsOn": "configure-release",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "--preset", "windows-mingw-debug"
      ],
      "dependsOn": "configure-debug",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "configure-release-linux",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "linux-release"],
      "problemMatcher": "$gcc"
    },
    {
      "label": "configure-debug-linux",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "linux-debug"],
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release-linux",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "linux-release"],
      "dependsOn": "configure-release-linux",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug-linux",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "linux-debug"],
      "dependsOn": "configure-debug-linux",
      "group": "build",
      "problemMatcher": "$gcc"
    }
  ]
}
