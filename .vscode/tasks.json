{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure-release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build/Release",
        "-DCMAKE_BUILD_TYPE=Release"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release",
      "dependsOn": [
        "configure-release",
        "build-release-only"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release-only",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build/Release"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "configure-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build/Debug",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug",
      "dependsOn": [
        "configure-debug",
        "build-debug-only"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug-only",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build/Debug"
      ],
      "problemMatcher": "$gcc"
    }
  ]
}
