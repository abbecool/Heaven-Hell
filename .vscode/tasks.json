{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure-release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "linux-release"
      ],
      "windows": {
        "command": "C:/msys64/ucrt64/bin/cmake.exe",
        "args": [
          "--preset",
          "windows-ninja-release"
        ],
        "options": {
          "env": {
            "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
          }
        }
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release",
      "dependsOn": [
        "configure-release",
        "build-release-only"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release-only",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "linux-release"
      ],
