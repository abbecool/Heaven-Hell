      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug-only",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build/Debug"
      ],
      "windows": {
        "command": "C:/msys64/ucrt64/bin/cmake.exe",
        "args": [
          "--build", "build/Windows/Ninja/Debug"
        ],
        "options": {
          "env": {
            "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
          }
        }
      },
      "problemMatcher": "$gcc"
