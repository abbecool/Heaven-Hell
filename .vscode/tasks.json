{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure-release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build/Release",
        "-DCMAKE_BUILD_TYPE=Release"
      ],
      "windows": {
        "args": [
          "-S", ".",
          "-B", "build/Windows/Release",
          "-DCMAKE_BUILD_TYPE=Release",
          "-G", "MinGW Makefiles"
        ]
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release",
      "dependsOn": [
        "configure-release",
        "build-release-only"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-release-only",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build/Release"
      ],
      "windows": {
        "args": [
          "--build", "build/Windows/Release"
        ]
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "configure-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build/Debug",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "windows": {
        "args": [
          "-S", ".",
          "-B", "build/Windows/Debug",
          "-DCMAKE_BUILD_TYPE=Debug",
          "-G", "MinGW Makefiles"
        ]
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug",
      "dependsOn": [
        "configure-debug",
        "build-debug-only"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "build-debug-only",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build/Debug"
      ],
      "windows": {
        "args": [
          "--build", "build/Windows/Debug"
        ]
      },
      "problemMatcher": "$gcc"
    }
  ]
}
