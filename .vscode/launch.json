{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run HeavenHell (GCC Release)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/run/Release/heavenhell.exe",
            "cwd": "${workspaceFolder}/run/Release",
            "preLaunchTask": "build-release",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe", // adjust if needed
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug HeavenHell (GCC Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/run/Debug/heavenhell.exe",
            "cwd": "${workspaceFolder}/run/Debug",
            "preLaunchTask": "build-debug",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe", // adjust if needed
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Run HeavenHell (Arch Release)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/run/Release/heavenhell",
            "cwd": "${workspaceFolder}/run/Release",
            "preLaunchTask": "build-release-linux",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug HeavenHell (Arch Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/run/Debug/heavenhell",
            "cwd": "${workspaceFolder}/run/Debug",
            "preLaunchTask": "build-debug-linux",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
                }
            ],
            "console": "integratedTerminal"
        }
    ]
}
